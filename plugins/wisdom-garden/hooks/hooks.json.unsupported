{
  "_note": "PostCompact is not a valid Claude Code hook event as of 2026-06-09; removed from hooks.json to unblock plugin load.",
  "PostCompact": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/log-compact-event.sh\"",
          "async": true
        }
      ]
    }
  ],
  "_note_stop_quarantine": "quarantined 2026-06-09 — fires a haiku eval on every session Stop; recurring cost/latency arrived via version bump; operator to opt in deliberately via OPERATIONS.md runbook",
  "Stop": [
    {
      "hooks": [
        {
          "type": "prompt",
          "prompt": "Review the conversation transcript. Did any significant insights, corrections, user preferences, or project decisions emerge during this session that are not yet captured in memory? If yes, respond with {\"ok\": false, \"reason\": \"Uncaptured insights: [list them briefly]\"} to continue the session for memory gardening. If memory is current or the session had no memorable learnings, respond with {\"ok\": true}.",
          "model": "claude-haiku-4-5"
        }
      ]
    }
  ]
}
