{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/batch-preflight.sh\"",
            "async": false,
            "if": "Bash(* batch-normalize*)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/artifact-tracking.sh\"",
            "async": true,
            "if": "Bash(* skill package*)"
          }
        ]
      }
    ]
  }
}
